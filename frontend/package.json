{
  "name": "lcn-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Frontend React de la bocadillería LCN (Mataró)",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "node --max-old-space-size=4096 node_modules/.bin/vitest run",
    "test:coverage": "node --max-old-space-size=4096 node_modules/.bin/vitest run --coverage --exclude 'src/test/components/ProtectedRoute.test.jsx' --exclude 'src/test/pages/PedidoDatos.test.jsx'"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.2",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "vite": "^5.4.8",
    "vitest": "^4.1.9"
  }
}
