# ============================================================
# frontend/.env.example
# Copia este archivo a .env.local y rellena los valores.
# NUNCA commitas .env.local (ya está en .gitignore).
# ============================================================

# URL base de la API REST del backend (sin barra final).
# En desarrollo local el backend escucha en el puerto 3001.
# En producción (GitHub Pages) el backend aún no está desplegado,
# por lo que esta variable puede quedar vacía (las llamadas fallarán
# con gracia — la UI muestra el estado de error correspondiente).
VITE_API_URL=http://localhost:3001

# Google OAuth 2.0 Web Client ID — PÚBLICA (segura en el bundle del navegador).
# Necesario para el botón "Continuar con Google" en /login y /registro.
# Cómo obtenerlo:
#   1. Ve a https://console.cloud.google.com/ → APIs y servicios → Credenciales.
#   2. Crea (o reutiliza) un "ID de cliente de OAuth 2.0" de tipo "Aplicación web".
#   3. Añade como orígenes JavaScript autorizados:
#        http://localhost:5173
#        https://jrero99.github.io
#   4. Copia el "ID de cliente" (termina en .apps.googleusercontent.com).
# Si se deja vacío, el botón de Google no se renderiza (sin error en la página).
VITE_GOOGLE_CLIENT_ID=
