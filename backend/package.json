{
  "name": "lcn-backend",
  "version": "1.0.0",
  "description": "La Casa Nostra — API REST (Node.js + Express + Prisma + PostgreSQL)",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node prisma/seed.js",
    "prisma:seed:catalog": "node prisma/seedCatalog.js",
    "prisma:reset": "prisma migrate reset"
  },
  "prisma": {
    "seed": "node -e \"import('./prisma/seed.js')\""
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "argon2": "^0.31.2",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.11.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "prisma": "^5.14.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
