{
  "name": "lcn-backend",
  "version": "1.0.0",
  "description": "La Casa Nostra — API REST (Node.js + Express + Prisma + PostgreSQL)",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "test": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --forceExit",
    "test:coverage": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --coverage --forceExit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node prisma/seed.js",
    "prisma:seed:catalog": "node prisma/seedCatalog.js",
    "prisma:reset": "prisma migrate reset"
  },
  "prisma": {
    "seed": "node -e \"import('./prisma/seed.js')\""
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "argon2": "^0.31.2",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "google-auth-library": "^10.7.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.11.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "prisma": "^5.14.0",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 90,
        "branches": 90,
        "functions": 90,
        "lines": 90
      }
    },
    "coverageReporters": ["text", "lcov"],
    "setupFiles": [
      "./tests/setup.js"
    ]
  }
}
