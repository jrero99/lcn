# ============================================================
# La Casa Nostra — Backend environment variables (EXAMPLE)
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# --- Database ---
# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/lcn_db"

# --- Server ---
PORT=3001
NODE_ENV=development

# --- JWT ---
# Access token (corta duracion — stateless)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_RANDOM_64_BYTE_HEX"
JWT_EXPIRES_IN="15m"

# Refresh token (larga duracion — almacenado en BD como hash SHA-256)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_REFRESH_SECRET="REPLACE_WITH_ANOTHER_RANDOM_64_BYTE_HEX"
JWT_REFRESH_EXPIRES_IN="30d"

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:5173,https://jrero99.github.io"

# --- Admin seed ---
# Cuenta ADMIN única. El email por defecto es el del negocio (business.js).
# Sobreescribe ADMIN_EMAIL solo si quieres otra dirección de acceso.
# La contraseña se usa SOLO en prisma/seed.js — nunca hardcodeada en código.
# ADMIN_EMAIL="lacasanostramataro@gmail.com"
ADMIN_INITIAL_PASSWORD="REPLACE_WITH_STRONG_PASSWORD"

# --- Google SSO ---
# OAuth 2.0 Web Client ID from Google Cloud Console (APIs & Services > Credentials).
# The frontend also needs this value as VITE_GOOGLE_CLIENT_ID (public, safe to expose).
# Leave empty in development to boot without SSO (POST /api/auth/google returns 503).
# Required in production.
GOOGLE_CLIENT_ID="REPLACE_WITH_GOOGLE_OAUTH_CLIENT_ID"

# --- Pendiente / futuro (NO activo en esta versión) ---
# Anti-bot (Cloudflare Turnstile) y OTP por SMS (Twilio) NO están implementados.
# Cuando se decidan, se añadirán aquí sus variables y el middleware correspondiente.
